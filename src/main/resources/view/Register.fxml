<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="brokercraft.controllers.RegisterController"
            styleClass="root-pane" prefWidth="1100" prefHeight="680">
    <left>
        <VBox styleClass="hero-panel" alignment="TOP_LEFT" spacing="20" prefWidth="440">
            <padding><Insets top="48" right="40" bottom="48" left="48"/></padding>
            <Label text="Become an Investor" styleClass="brand-title"/>
            <Label text="Join BrokerCraft and get a dedicated broker after admin verification."
                   styleClass="brand-tagline" wrapText="true" maxWidth="340"/>
            <VBox spacing="10" styleClass="insight-box">
                <Label text="What you get" style="-fx-text-fill: #c7d2fe; -fx-font-weight: bold;"/>
                <Label text="100,000 ETB starting balance" styleClass="feature-pill"/>
                <Label text="Real-time portfolio &amp; charts" styleClass="feature-pill"/>
                <Label text="Secure broker-assisted trading" styleClass="feature-pill"/>
            </VBox>
        </VBox>
    </left>
    <center>
        <VBox alignment="CENTER" styleClass="root-pane">
            <VBox styleClass="login-card" spacing="14" maxWidth="440" alignment="CENTER_LEFT">
                <Label text="Application Form" styleClass="title"/>
                <Label text="Fields marked below are required" styleClass="subtitle"/>
                <Label text="FULL NAME" styleClass="field-label"/>
                <TextField fx:id="fullNameField" promptText="Legal name" maxWidth="Infinity"/>
                <Label text="USERNAME" styleClass="field-label"/>
                <TextField fx:id="usernameField" promptText="Unique username" maxWidth="Infinity"/>
                <Label text="EMAIL" styleClass="field-label"/>
                <TextField fx:id="emailField" promptText="Contact email" maxWidth="Infinity"/>
                <Label text="PASSWORD" styleClass="field-label"/>
                <PasswordField fx:id="passwordField" maxWidth="Infinity"/>
                <Label text="CONFIRM" styleClass="field-label"/>
                <PasswordField fx:id="confirmField" maxWidth="Infinity"/>
                <Label fx:id="messageLabel" wrapText="true"/>
                <HBox spacing="12">
                    <Button text="Submit Application" onAction="#onSubmit" styleClass="button-primary" HBox.hgrow="ALWAYS"/>
                    <Button text="Back" onAction="#onBack" styleClass="button-ghost" HBox.hgrow="ALWAYS"/>
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
