<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="brokercraft.controllers.BrokerDashboardController"
            styleClass="root-pane" prefWidth="1200" prefHeight="760">
    <top>
        <VBox spacing="14">
            <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="16">
                <Label text="BrokerCraft" styleClass="logo-mark"/>
                <Label text="Advisor Workstation" styleClass="subtitle"/>
                <Separator orientation="VERTICAL"/>
                <Label fx:id="welcomeLabel" styleClass="section-title"/>
                <Label fx:id="clockLabel" styleClass="subtitle"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Button text="Refresh" onAction="#onRefresh" styleClass="button-secondary"/>
                <Button text="Logout" onAction="#onLogout" styleClass="button-danger"/>
            </HBox>
            <HBox spacing="14">
                <padding><Insets left="20" right="20"/></padding>
                <VBox styleClass="metric-card-highlight" spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="ASSIGNED CLIENTS" styleClass="metric-label"/>
                    <Label fx:id="clientCountLabel" styleClass="metric-value"/>
                </VBox>
                <VBox styleClass="metric-card" spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="CLIENT AUM (SELECTED)" styleClass="metric-label"/>
                    <Label fx:id="clientAumLabel" styleClass="metric-value"/>
                </VBox>
                <VBox styleClass="metric-card" spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="TRADES TODAY" styleClass="metric-label"/>
                    <Label fx:id="tradesTodayLabel" styleClass="metric-value"/>
                </VBox>
                <VBox styleClass="metric-card" spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="MARKET STATUS" styleClass="metric-label"/>
                    <Label text="Live" styleClass="metric-value" style="-fx-text-fill: #4ade80;"/>
                </VBox>
            </HBox>
        </VBox>
    </top>
    <center>
        <HBox spacing="18">
            <padding><Insets top="8" right="20" bottom="16" left="20"/></padding>
            <VBox styleClass="sidebar" spacing="12" prefWidth="280">
                <Label text="Client Book" styleClass="section-title"/>
                <TextField fx:id="clientSearchField" promptText="Search clients..."
                           styleClass="search-field" maxWidth="Infinity"/>
                <ListView fx:id="clientsList" VBox.vgrow="ALWAYS" minHeight="220"/>
                <VBox styleClass="metric-card" spacing="6">
                    <Label text="SELECTED" styleClass="metric-label"/>
                    <Label fx:id="selectedClientLabel" wrapText="true" styleClass="subtitle"/>
                    <Label fx:id="clientBalanceLabel" styleClass="badge-balance"/>
                </VBox>
            </VBox>
            <TabPane tabClosingPolicy="UNAVAILABLE" HBox.hgrow="ALWAYS">
                <Tab text="Market &amp; Trade">
                    <VBox spacing="14">
                        <VBox styleClass="card" spacing="10">
                            <Label text="Market Watch" styleClass="section-title"/>
                            <TableView fx:id="marketTable" prefHeight="180">
                                <columns>
                                    <TableColumn fx:id="stockSymbolCol" text="Symbol" prefWidth="100"/>
                                    <TableColumn fx:id="stockNameCol" text="Company" prefWidth="200"/>
                                    <TableColumn fx:id="stockPriceCol" text="Price" prefWidth="120"/>
                                </columns>
                            </TableView>
                        </VBox>
                        <HBox spacing="18">
                            <VBox styleClass="card" spacing="10" HBox.hgrow="ALWAYS">
                                <Label text="Client Holdings" styleClass="section-title"/>
                                <TableView fx:id="portfolioTable" prefHeight="160">
                                    <columns>
                                        <TableColumn fx:id="portSymbolCol" text="Symbol" prefWidth="100"/>
                                        <TableColumn fx:id="portQtyCol" text="Shares" prefWidth="90"/>
                                        <TableColumn fx:id="portValueCol" text="Value" prefWidth="120"/>
                                    </columns>
                                </TableView>
                            </VBox>
                            <VBox styleClass="trade-panel" spacing="12" prefWidth="320">
                                <Label text="Execute for Client" styleClass="section-title"/>
                                <ComboBox fx:id="tradeSymbolCombo" maxWidth="Infinity"/>
                                <TextField fx:id="quantityField" promptText="Quantity" maxWidth="Infinity"/>
                                <Label fx:id="brokerEstimateLabel" wrapText="true" styleClass="subtitle"/>
                                <HBox spacing="10">
                                    <Button text="BUY" onAction="#onBuy" styleClass="button-buy" HBox.hgrow="ALWAYS"/>
                                    <Button text="SELL" onAction="#onSell" styleClass="button-sell" HBox.hgrow="ALWAYS"/>
                                </HBox>
                                <Label fx:id="tradeMessageLabel" wrapText="true"/>
                            </VBox>
                        </HBox>
                    </VBox>
                </Tab>
                <Tab text="Activity">
                    <VBox styleClass="card" spacing="10">
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Client Transaction Feed" styleClass="section-title"/>
                            <Pane HBox.hgrow="ALWAYS"/>
                            <ComboBox fx:id="activityFilterCombo" prefWidth="120"/>
                        </HBox>
                        <TableView fx:id="txTable" VBox.vgrow="ALWAYS" minHeight="400">
                            <columns>
                                <TableColumn fx:id="txTimeCol" text="Time" prefWidth="160"/>
                                <TableColumn fx:id="txClientCol" text="Client" prefWidth="140"/>
                                <TableColumn fx:id="txTypeCol" text="Side" prefWidth="80"/>
                                <TableColumn fx:id="txSymbolCol" text="Symbol" prefWidth="90"/>
                                <TableColumn fx:id="txQtyCol" text="Qty" prefWidth="70"/>
                            </columns>
                        </TableView>
                    </VBox>
                </Tab>
            </TabPane>
        </HBox>
    </center>
    <bottom>
        <HBox styleClass="status-footer">
            <Label fx:id="footerLabel" styleClass="subtitle"/>
            <Pane HBox.hgrow="ALWAYS"/>
        </HBox>
    </bottom>
</BorderPane>
